        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Fai doppio clic per riprovare a caricare gli account"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "계정 로드를 다시 시도하려면 두 번 탭하세요"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
