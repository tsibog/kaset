    "This video is playing in the pop-out player.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يتم تشغيل هذا الفيديو في المشغّل المنبثق."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dieses Video wird im ausgelagerten Player wiedergegeben."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Este video se está reproduciendo en el reproductor emergente."
          }
        },
        "fr": {
