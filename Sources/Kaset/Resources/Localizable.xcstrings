    "Adds a third 'smart' state to the shuffle button that interleaves recommended tracks into your queue": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يضيف حالة \"ذكية\" ثالثة إلى زر الخلط لإدراج المقطوعات المقترحة ضمن قائمة التشغيل"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Fügt der Taste für die Zufallswiedergabe einen dritten „intelligenten“ Zustand hinzu, der empfohlene Titel in deine Warteschlange einstreut"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Añade un tercer estado \"inteligente\" al botón de aleatorio que intercala pistas recomendadas en tu cola"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ajoute un troisième état « intelligent » au bouton de lecture aléatoire qui intègre des titres recommandés à votre file d’attente"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Menambahkan status \"cerdas\" ketiga ke tombol acak yang menyisipkan trek rekomendasi ke antrean Anda"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Aggiunge un terzo stato 'intelligente' al pulsante Casuale che intreccia i brani consigliati nella tua coda"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "셔플 버튼에 추천 트랙을 대기열에 끼워 넣는 세 번째 '스마트' 상태를 추가합니다"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Voegt een derde 'slimme' stand toe aan de shuffleknop die aanbevolen nummers tussen je wachtrij plaatst"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Dodaje trzeci, „inteligentny” stan do przycisku losowania, który przeplata polecane utwory z Twoją kolejką"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Adiciona um terceiro estado \"inteligente\" ao botão Aleatório que intercala faixas recomendadas na sua fila"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Добавляет третье «умное» состояние кнопке перемешивания, которое вставляет рекомендованные треки в вашу очередь"
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Lägger till ett tredje ”smart” läge på blandningsknappen som väver in rekommenderade spår i din kö"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Karıştırma düğmesine, önerilen parçaları kuyruğunuza ekleyen üçüncü bir \"akıllı\" durum ekler"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Додає третій «розумний» стан кнопки перемішування, який чергує рекомендовані треки у вашій черзі"
          }
        }
      }
    },
