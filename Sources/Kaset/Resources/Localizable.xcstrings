            "value": "Qui appaiono i video dei canali a cui sei iscritto."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "구독 중인 채널의 동영상이 여기에 표시됩니다."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Video's van kanalen waarop je bent geabonneerd verschijnen hier."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Tutaj pojawią się filmy z kanałów, które subskrybujesz."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Os vídeos dos canais que subscreve aparecem aqui."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Здесь появятся видео с каналов, на которые вы подписаны."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Videor från kanaler du prenumererar på visas här."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Abone olduğunuz kanallardaki videolar burada görünür."
