    "Videos from channels you subscribe to appear here.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تظهر هنا الفيديوهات من القنوات التي تشترك فيها."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Videos von Kanälen, die du abonniert hast, erscheinen hier."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Aquí aparecen los videos de los canales a los que estás suscrito."
          }
