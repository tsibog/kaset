    "Clear the entire queue and stop playback.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "امسح قائمة الانتظار بالكامل وأوقف التشغيل."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Leere die gesamte Warteschlange und stoppe die Wiedergabe."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Borra toda la cola y detén la reproducción."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Efface toute la file d'attente et arrête la lecture."
          }
        },
        "id": {
