    "Only WebKit-compatible extensions (with a valid **manifest.json**) are supported.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يتم دعم الإضافات المتوافقة مع WebKit فقط (مع **manifest.json** صالح)."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Es werden nur WebKit-kompatible Erweiterungen (mit gültiger **manifest.json**) unterstützt."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Solo se admiten extensiones compatibles con WebKit (con un **manifest.json** válido)."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Seules les extensions compatibles WebKit (avec un **manifest.json** valide) sont prises en charge."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Hanya ekstensi yang kompatibel dengan WebKit (dengan **manifest.json** yang valid) yang didukung."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Sono supportate solo le estensioni compatibili con WebKit (con un **manifest.json** valido)."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "유효한 **manifest.json**이 있는 WebKit 호환 확장 프로그램만 지원됩니다."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Alleen WebKit-compatibele extensies (met een geldige **manifest.json**) worden ondersteund."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Obsługiwane są tylko rozszerzenia zgodne z WebKit (z prawidłowym plikiem **manifest.json**)."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Apenas extensões compatíveis com WebKit (com um **manifest.json** válido) são suportadas."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Поддерживаются только расширения, совместимые с WebKit (с корректным **manifest.json**)."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Endast WebKit-kompatibla tillägg (med en giltig **manifest.json**) stöds."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
