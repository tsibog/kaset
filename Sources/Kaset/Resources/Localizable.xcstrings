        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Baraja la cola manteniendo la canción actual al principio."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Mélangez la file d'attente en gardant le morceau en cours en premier."
