    "Remove Duplicates: delete repeated songs from the queue and keep the first occurrence of each.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "إزالة التكرارات: احذف الأغاني المكررة من قائمة الانتظار واحتفظ بأول ظهور لكل أغنية."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Doppelte entfernen: Löscht wiederholte Titel aus der Warteschlange und behält jeweils das erste Vorkommen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Eliminar duplicados: elimina las canciones repetidas de la cola y conserva la primera aparición de cada una."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Supprimer les doublons : supprime les morceaux répétés de la file d'attente et conserve la première occurrence de chacun."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Hapus Duplikat: hapus lagu berulang dari antrean dan pertahankan kemunculan pertama setiap lagu."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Rimuovi duplicati: elimina i brani ripetuti dalla coda e conserva la prima occorrenza di ciascuno."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "중복 제거: 대기열에서 반복된 노래를 삭제하고 각 노래의 첫 번째 항목만 유지합니다."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Duplicaten verwijderen: verwijdert dubbele nummers uit de wachtrij en behoudt van elk nummer de eerste vermelding."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Usuń duplikaty: usuń powtarzające się utwory z kolejki i zachowaj pierwsze wystąpienie każdego z nich."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Remover duplicados: elimine músicas repetidas da fila e mantenha a primeira ocorrência de cada uma."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Удалить дубликаты: удаляет повторяющиеся песни из очереди и оставляет первое вхождение каждой."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Ta bort dubbletter: radera upprepade låtar från kön och behåll den första förekomsten av varje."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Yinelenenleri kaldır: kuyruktaki tekrar eden şarkıları siler ve her birinin ilk örneğini korur."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Видалити дублікати: видаляє повторювані пісні з черги й залишає перше входження кожної."
          }
        }
      }
    },
