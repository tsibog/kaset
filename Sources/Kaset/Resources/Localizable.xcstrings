    "Force macOS 15 fallback views and materials while running on macOS 26+ for compatibility debugging": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "فرض استخدام الواجهات والمواد الاحتياطية الخاصة بـ macOS 15 أثناء التشغيل على macOS 26+ لتصحيح التوافق"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Erzwingt Fallback-Ansichten und -Materialien von macOS 15 unter macOS 26+ zur Kompatibilitätsprüfung"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Fuerza vistas y materiales de respaldo de macOS 15 al ejecutarse en macOS 26+ para depurar compatibilidad"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Force les vues et matériaux de repli de macOS 15 lors de l'exécution sur macOS 26+ pour le débogage de compatibilité"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Paksa tampilan dan material fallback macOS 15 saat berjalan di macOS 26+ untuk debugging kompatibilitas"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Forza viste e materiali di fallback di macOS 15 durante l'esecuzione su macOS 26+ per il debug della compatibilità"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "호환성 디버깅을 위해 macOS 26+에서 실행 중일 때 macOS 15 대체 보기와 머티리얼을 강제로 사용합니다"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Forceert macOS 15-terugvalweergaven en -materialen tijdens uitvoering op macOS 26+ voor compatibiliteitsdebugging"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wymusza widoki i materiały awaryjne z macOS 15 podczas działania na macOS 26+ w celu debugowania zgodności"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Força as vistas e materiais de contingência do macOS 15 ao executar no macOS 26+ para depuração de compatibilidade"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Принудительно использует резервные представления и материалы macOS 15 при работе на macOS 26+ для отладки совместимости"
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Tvingar reservvyer och material från macOS 15 när appen körs på macOS 26+ för kompatibilitetsfelsökning"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Uyumluluk hatalarını ayıklamak için macOS 26+ üzerinde çalışırken macOS 15 yedek görünümlerini ve materyallerini zorlar"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Примусово використовує резервні подання й матеріали macOS 15 під час роботи на macOS 26+ для налагодження сумісності"
          }
        }
      }
    },
