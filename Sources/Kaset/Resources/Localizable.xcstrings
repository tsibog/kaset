          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Cofnij ostatnią zmianę kolejki."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Anule a última alteração da fila."
          }
        },
        "ru": {
