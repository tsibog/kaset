            "state": "translated",
            "value": "Отмените последнее изменение в очереди."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Ångra den senaste köändringen."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Son kuyruk değişikliğini geri al."
          }
        },
