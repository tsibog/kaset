    "Double-tap to retry loading accounts": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "انقر مرتين لإعادة محاولة تحميل الحسابات"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Doppelklicken, um das Laden der Accounts erneut zu versuchen"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Haz doble clic para reintentar cargar las cuentas"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Double-cliquez pour réessayer de charger les comptes"
          }
