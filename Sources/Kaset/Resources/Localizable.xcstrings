        }
      }
    },
    "The system didn't report a valid audio format for Kaset's output. Try disabling the equalizer, starting playback, then enabling it again.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لم يُبلّغ النظام عن تنسيق صوت صالح لإخراج Kaset. حاول إيقاف المعادل وبدء التشغيل ثم إعادة تشغيله."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Das System hat kein gültiges Audioformat für Kasets Ausgabe gemeldet. Versuche, den Equalizer zu deaktivieren, die Wiedergabe zu starten und ihn dann erneut zu aktivieren."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El sistema no informó de un formato de audio válido para la salida de Kaset. Prueba a desactivar el ecualizador, iniciar la reproducción y volver a activarlo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le système n'a pas signalé un format audio valide pour la sortie de Kaset. Désactivez l'égaliseur, lancez la lecture, puis réactivez-le."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Sistem tidak melaporkan format audio yang valid untuk output Kaset. Coba nonaktifkan equalizer, mulai pemutaran, lalu aktifkan kembali."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il sistema non ha segnalato un formato audio valido per l'uscita di Kaset. Prova a disabilitare l'equalizzatore, avviare la riproduzione e poi riabilitarlo."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Kaset 출력에 유효한 오디오 형식이 보고되지 않았습니다. 이퀄라이저를 끄고 재생을 시작한 후 다시 켜보세요."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Het systeem meldde geen geldige audio-indeling voor de uitvoer van Kaset. Probeer de equalizer uit te schakelen, het afspelen te starten en hem daarna opnieuw in te schakelen."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "System nie zgłosił prawidłowego formatu audio dla wyjścia Kaset. Spróbuj wyłączyć korektor, rozpocząć odtwarzanie, a potem włączyć go ponownie."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "O sistema não comunicou um formato de áudio válido para a saída do Kaset. Tente desativar o equalizador, iniciar a reprodução e voltar a ativá-lo."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Система не сообщила допустимый аудиоформат для выхода Kaset. Попробуйте отключить эквалайзер, начать воспроизведение, а затем включить его снова."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Systemet rapporterade inget giltigt ljudformat för Kasets utgång. Prova att stänga av equalizern, starta uppspelning och slå sedan på den igen."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Sistem Kaset'in çıkışı için geçerli bir ses biçimi bildirmedi. Ekolayzırı kapatıp oynatmayı başlatın, ardından yeniden açın."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Система не повідомила дійсний аудіоформат для виходу Kaset. Спробуйте вимкнути еквалайзер, почати відтворення, а потім увімкнути його знову."
          }
        }
      }
    },
