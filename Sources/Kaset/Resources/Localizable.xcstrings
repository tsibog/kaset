    "How far apart suggestions are placed (every N of your playlist's songs)": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "مدى تباعد الاقتراحات (كل N من أغاني قائمتك)"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wie weit Vorschläge voneinander entfernt eingefügt werden (nach jeweils N Titeln deiner Playlist)"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Con qué separación se colocan las sugerencias (cada N canciones de tu playlist)"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Espacement des suggestions (tous les N morceaux de votre playlist)"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Seberapa jauh jarak antar saran (setiap N lagu di daftar putar Anda)"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Quanto distanziare i suggerimenti (ogni N brani della tua playlist)"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "추천이 배치되는 간격(재생목록 곡 N개마다)"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Hoe ver suggesties uit elkaar worden geplaatst (elke N nummers van je afspeellijst)"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Jak często umieszczane są sugestie (co N utworów z playlisty)"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Qual a distância entre sugestões (a cada N músicas da sua lista de reprodução)"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Как часто размещать рекомендации (каждые N треков вашего плейлиста)"
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Hur ofta förslag placeras (var N:e låt i spellistan)"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Önerilerin ne sıklıkta yerleştirileceği (çalma listenizdeki her N şarkıda bir)"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Як часто розміщуються пропозиції (кожні N пісень у вашому плейлисті)"
          }
        }
      }
    },
