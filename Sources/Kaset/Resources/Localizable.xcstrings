    "Play songs from a playlist or album to build your queue.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "شغّل أغاني من قائمة تشغيل أو ألبوم لبناء قائمة الانتظار."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Spiele Titel aus einer Playlist oder einem Album ab, um deine Warteschlange zu füllen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Reproduce canciones desde una playlist o un álbum para crear tu cola."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Lancez des morceaux depuis une playlist ou un album pour créer votre file d'attente."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Putar lagu dari daftar putar atau album untuk membangun antrean Anda."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Riproduci brani da una playlist o da un album per creare la tua coda."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "대기열을 만들려면 재생목록이나 앨범에서 노래를 재생하세요."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Speel nummers uit een afspeellijst of album af om je wachtrij op te bouwen."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Odtwarzaj utwory z playlisty lub albumu, aby zbudować swoją kolejkę."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Reproduza músicas de uma lista de reprodução ou álbum para criar a sua fila."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Воспроизводите треки из плейлиста или альбома, чтобы собрать свою очередь."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Spela låtar från en spellista eller ett album för att bygga din kö."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Sıranızı oluşturmak için bir çalma listesinden veya albümden şarkılar çalın."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Грайте пісні з плейлиста або альбому, щоб сформувати чергу."
          }
        }
      }
    },
