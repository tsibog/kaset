    "Shuffle the queue, keeping the current song first.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "اخلط قائمة الانتظار مع إبقاء الأغنية الحالية أولًا."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Mische die Warteschlange und behalte den aktuellen Titel an erster Stelle."
