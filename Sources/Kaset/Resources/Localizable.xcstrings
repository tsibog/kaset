    },
    "Undo the last queue change.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تراجع عن آخر تغيير في قائمة الانتظار."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Mache die letzte Änderung an der Warteschlange rückgängig."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Deshaz el último cambio de la cola."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Annulez la dernière modification de la file d'attente."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Batalkan perubahan antrean terakhir."
          }
        },
        "it": {
